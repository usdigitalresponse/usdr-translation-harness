.env
__pycache__/
*.pyc
.venv/
# Ignore .claude internals but commit skills so contributors have dev tooling.
# Revisit if .claude/skills grows to include anything not suitable for a public repo.
.claude/*
!.claude/skills/
.claude/skills/task-to-todo/

.DS_Store
scratch.*
node_modules/
cloud-run/.venv/
cloud-run/*/fixtures/output/

# clasp credentials (not the project config .clasp.json, which should be committed)
.clasprc.json

# Internal reference docs (specs, working notes) — not for public repo
docs/internal/

drafts/
