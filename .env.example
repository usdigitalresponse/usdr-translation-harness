# =============================================================================
# MD Translation Prototype — Environment Variables
# List is to delineate what's required and enable running locally
# Copy this file to .env and fill in the values.
# DO NOT commit .env to the repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Drive Folders
# -----------------------------------------------------------------------------
# Folder where source PDFs are uploaded for processing
DRIVE_INPUT_FOLDER_ID=

# Folder where extraction JSON output is stored
DRIVE_EXTRACTION_JSON_FOLDER_ID=

# Folder where translation JSON output is stored
DRIVE_TRANSLATION_JSON_FOLDER_ID=

# Folder where eval results are stored
DRIVE_EVAL_RESULTS_FOLDER_ID=

# Folder where output Google Docs are created for reviewer
DRIVE_OUTPUT_DOCS_FOLDER_ID=

# -----------------------------------------------------------------------------
# Google Docs
# -----------------------------------------------------------------------------
# Translation prompt — style guide, tone criteria, golden examples
TRANSLATION_PROMPT_DOC_ID=

# Extraction prompt — instructions for identifying text blocks from PDFs
EXTRACTION_PROMPT_DOC_ID=

# Evaluation rubric — criteria for LLM-as-judge scoring
EVALUATION_RUBRIC_DOC_ID=

# Output template — formatting-only doc copied by Translate function
OUTPUT_TEMPLATE_DOC_ID=

# -----------------------------------------------------------------------------
# Google Sheets
# -----------------------------------------------------------------------------
# Model config — provider, model ID, active flag, role
MODEL_CONFIG_SHEET_ID=

# Glossary — terminology decisions accumulated from reviewer feedback
GLOSSARY_SHEET_ID=

# Golden translation set — source/reference pairs for drift eval
GOLDEN_SET_SHEET_ID=

# Eval results — scores from drift and quality evals
EVAL_DRIFT_RESULTS_SHEET_ID=
EVAL_QUALITY_RESULTS_SHEET_ID=

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# GCP (populate once project is provisioned)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=
PUBSUB_TOPIC_EXTRACTION_COMPLETE=
CLOUD_RUN_SERVICE_ACCOUNT_EMAIL=
