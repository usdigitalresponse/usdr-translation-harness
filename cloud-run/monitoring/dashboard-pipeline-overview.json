{
  "displayName": "Translation Pipeline - Overview",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 12,
        "height": 2,
        "widget": {
          "title": "",
          "text": {
            "content": "# Translation Pipeline Overview\nCloud Run function health, throughput, and latency across extract, translate, and capture-feedback.",
            "format": "MARKDOWN"
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 2,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Request Count by Function",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"run.googleapis.com/request_count\" AND resource.label.\"service_name\"=monitoring.regex.full_match(\"extract|translate|capture-feedback\")",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.label.\"service_name\""]
                    }
                  }
                },
                "plotType": "STACKED_BAR"
              }
            ],
            "yAxis": { "label": "requests/sec" }
          }
        }
      },
      {
        "xPos": 4,
        "yPos": 2,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Request Latency p50 (ms)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"run.googleapis.com/request_latencies\" AND resource.label.\"service_name\"=monitoring.regex.full_match(\"extract|translate|capture-feedback\")",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_50",
                      "crossSeriesReducer": "REDUCE_MEAN",
                      "groupByFields": ["resource.label.\"service_name\""]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "label": "ms" }
          }
        }
      },
      {
        "xPos": 8,
        "yPos": 2,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Request Latency p95 (ms)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"run.googleapis.com/request_latencies\" AND resource.label.\"service_name\"=monitoring.regex.full_match(\"extract|translate|capture-feedback\")",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "crossSeriesReducer": "REDUCE_MEAN",
                      "groupByFields": ["resource.label.\"service_name\""]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "label": "ms" }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 6,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Pipeline Stage Executions (by stage & status)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"logging.googleapis.com/user/pipeline_stage_status\"",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["metric.label.\"pipeline_stage\"", "metric.label.\"status\""]
                    }
                  }
                },
                "plotType": "STACKED_BAR"
              }
            ],
            "yAxis": { "label": "events/sec" }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 6,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Translations by Provider / Model",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"logging.googleapis.com/user/pipeline_stage_status\" AND metric.label.\"pipeline_stage\"=\"translate\"",
                    "aggregation": {
                      "alignmentPeriod": "86400s",
                      "perSeriesAligner": "ALIGN_SUM",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["metric.label.\"provider\"", "metric.label.\"model\""]
                    }
                  }
                },
                "plotType": "STACKED_BAR",
                "legendTemplate": "${metric.labels.provider}/${metric.labels.model}"
              }
            ],
            "yAxis": { "label": "translations" }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 10,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "5xx Error Rate by Function",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"run.googleapis.com/request_count\" AND resource.label.\"service_name\"=monitoring.regex.full_match(\"extract|translate|capture-feedback\") AND metric.label.\"response_code_class\"=\"5xx\"",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.label.\"service_name\""]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "label": "errors/sec" }
          }
        }
      },
      {
        "xPos": 4,
        "yPos": 10,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Container Instance Count",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"run.googleapis.com/container/instance_count\" AND resource.label.\"service_name\"=monitoring.regex.full_match(\"extract|translate|capture-feedback\")",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.label.\"service_name\""]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "label": "instances" }
          }
        }
      },
      {
        "xPos": 8,
        "yPos": 10,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Memory Utilization (p95)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"run.googleapis.com/container/memory/utilizations\" AND resource.label.\"service_name\"=monitoring.regex.full_match(\"extract|translate|capture-feedback\")",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "crossSeriesReducer": "REDUCE_MEAN",
                      "groupByFields": ["resource.label.\"service_name\""]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "label": "utilization" }
          }
        }
      }
    ]
  }
}
