{
  "type": "object",
  "properties": {
    "blocks": {
      "type": "array",
      "description": "One entry per translatable block from the extraction JSON, in the same order, keyed by block ID",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Block ID from the extraction JSON (e.g. b01, b02)"
          },
          "original_text": {
            "type": "string",
            "description": "The source English text of this block"
          },
          "translated_text": {
            "type": "string",
            "description": "The Spanish translation of this block"
          },
          "alt_translations": {
            "type": "array",
            "description": "Alternative translations considered for specific phrases in this block",
            "items": {
              "type": "object",
              "properties": {
                "original_phrase": { "type": "string" },
                "primary_translation": { "type": "string" },
                "alt_translation": { "type": "string" },
                "rationale": { "type": "string" }
              },
              "required": ["original_phrase", "primary_translation", "alt_translation", "rationale"],
              "additionalProperties": false
            }
          },
          "terms_flagged_for_clarification": {
            "type": "array",
            "description": "Terms or phrases in this block flagged due to ambiguity or insufficient context",
            "items": {
              "type": "object",
              "properties": {
                "original_phrase": { "type": "string" },
                "translation": { "type": "string" },
                "needed_clarification": { "type": "string" }
              },
              "required": ["original_phrase", "translation", "needed_clarification"],
              "additionalProperties": false
            }
          },
          "back_translation_of_key_phrases": {
            "type": "array",
            "description": "Back-translations of complex or high-stakes phrases in this block to aid semantic review",
            "items": {
              "type": "object",
              "properties": {
                "original_phrase": { "type": "string" },
                "translation": { "type": "string" },
                "back_translation": { "type": "string" }
              },
              "required": ["original_phrase", "translation", "back_translation"],
              "additionalProperties": false
            }
          },
          "glossary_cross_check": {
            "type": "array",
            "description": "Notes on glossary adherence or deviation for terms in this block",
            "items": {
              "type": "object",
              "properties": {
                "term": { "type": "string" },
                "translation": { "type": "string" },
                "status": {
                  "type": "string",
                  "description": "Whether the glossary was followed or deviated from, e.g. 'followed' or 'deviated'"
                },
                "note": { "type": "string" }
              },
              "required": ["term", "translation", "status", "note"],
              "additionalProperties": false
            }
          }
        },
        "required": ["id", "original_text", "translated_text", "alt_translations", "terms_flagged_for_clarification", "back_translation_of_key_phrases", "glossary_cross_check"],
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "description": "Document-level translation metadata",
      "properties": {
        "source_language": { "type": "string" },
        "target_language": { "type": "string" },
        "overall_notes": {
          "type": "string",
          "description": "Any document-wide observations about the translation (e.g. register consistency, recurring challenges)"
        }
      },
      "required": ["source_language", "target_language", "overall_notes"],
      "additionalProperties": false
    }
  },
  "required": ["blocks", "metadata"],
  "additionalProperties": false
}
